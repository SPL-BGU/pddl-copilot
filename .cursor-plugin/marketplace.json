{
  "name": "pddl-copilot-marketplace",
  "owner": {
    "name": "SPL-BGU"
  },
  "metadata": {
    "description": "PDDL planning tools marketplace",
    "version": "1.2.0",
    "pluginRoot": "plugins"
  },
  "plugins": [
    {
      "name": "pddl-solver",
      "description": "Solve PDDL planning problems — supports classical and numeric (PDDL 2.1) domains. Runs in Docker.",
      "source": "./plugins/pddl-solver",
      "author": {
        "name": "SPL-BGU"
      },
      "license": "MIT",
      "version": "1.2.0",
      "homepage": "https://github.com/SPL-BGU/pddl-copilot",
      "repository": "https://github.com/SPL-BGU/pddl-copilot",
      "category": "planning",
      "keywords": ["pddl", "planning", "fast-downward", "metric-ff"]
    },
    {
      "name": "pddl-validator",
      "description": "Validate PDDL domains, problems, and plans — check syntax, verify plan correctness, and inspect state transitions. Runs in Docker.",
      "source": "./plugins/pddl-validator",
      "author": {
        "name": "SPL-BGU"
      },
      "license": "MIT",
      "version": "1.2.0",
      "homepage": "https://github.com/SPL-BGU/pddl-copilot",
      "repository": "https://github.com/SPL-BGU/pddl-copilot",
      "category": "planning",
      "keywords": ["pddl", "validation", "val", "state-transition"]
    },
    {
      "name": "pddl-parser",
      "description": "PDDL introspection, trajectory generation, applicability checking, and state analysis. Pure Python, no Docker.",
      "source": "./plugins/pddl-parser",
      "author": {
        "name": "SPL-BGU"
      },
      "license": "MIT",
      "version": "1.2.0",
      "homepage": "https://github.com/SPL-BGU/pddl-copilot",
      "repository": "https://github.com/SPL-BGU/pddl-copilot",
      "category": "planning",
      "keywords": ["pddl", "parser", "trajectory", "state-transition", "introspection", "applicability"]
    }
  ]
}
